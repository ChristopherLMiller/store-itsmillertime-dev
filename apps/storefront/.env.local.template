# Copy to .env.local and fill in values.

# Medusa backend (create a publishable API key in Admin → Settings → Publishable API Keys)
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Storefront
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_REGION=us

# Must match ECOMMERCE_ENVIRONMENT in apps/backend/.env
NEXT_PUBLIC_ECOMMERCE_ENVIRONMENT=sandbox

# Stripe publishable keys (Dashboard → Developers → API keys)
NEXT_PUBLIC_STRIPE_SANDBOX_KEY=
NEXT_PUBLIC_STRIPE_LIVE_KEY=
