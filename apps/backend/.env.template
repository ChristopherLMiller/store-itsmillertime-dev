STORE_CORS=http://localhost:8000,http://localhost:3000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=
DB_NAME=medusa-backend

# --- First-time setup ---
# 1. Copy this file to .env and fill in DATABASE_URL + secrets above.
# 2. Start Postgres + Redis.
# 3. cd apps/backend && pnpm medusa db:migrate
# 4. pnpm dev   (or from repo root: pnpm backend:dev)

# --- File storage (Cloudflare R2 / S3) ---
# Set these to store uploads (product images) in R2 so they render on the
# storefront. Leave them blank to use local file storage in dev.
# R2_BUCKET=your-bucket
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_FILE_URL=https://pub-xxxx.r2.dev   # public base URL for the bucket
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_REGION=auto
# R2_PREFIX=

# --- Prodigi Print-on-Demand ---
# Toggle between sandbox and live with PRODIGI_ENVIRONMENT.
# When sandbox: uses PRODIGI_SANDBOX_API_KEY (falls back to PRODIGI_API_KEY).
# When live: uses PRODIGI_API_KEY.
PRODIGI_ENVIRONMENT=sandbox
PRODIGI_SANDBOX_API_KEY=
PRODIGI_API_KEY=
# Optional: override the API base URL (defaults to sandbox/live Prodigi URLs)
# PRODIGI_API_URL=https://api.sandbox.prodigi.com
# PRODIGI_SANDBOX_API_URL=https://api.sandbox.prodigi.com
# PRODIGI_LIVE_API_URL=https://api.prodigi.com
# Webhook secret for callback route verification (unguessable path segment).
# Callbacks arrive at: {MEDUSA_BACKEND_URL}/hooks/prodigi/{PRODIGI_WEBHOOK_SECRET}
# PRODIGI_WEBHOOK_SECRET=
# Public URL of this backend, used to build the Prodigi callback URL
# MEDUSA_BACKEND_URL=https://your-backend.example.com
# Currency for Prodigi shipping quotes at checkout (default USD)
# PRODIGI_QUOTE_CURRENCY=USD
# Reference destination when quoting print unit costs for the catalog (default US)
# PRODIGI_QUOTE_DESTINATION=US
# Shipping method passed to Prodigi quote requests (default Standard)
# PRODIGI_QUOTE_SHIPPING_METHOD=Standard
# Default markup % applied to Prodigi print cost when creating offerings (default 20)
# PRODIGI_DEFAULT_MARKUP_PERCENT=20
